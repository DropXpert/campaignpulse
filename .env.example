# App
NEXT_PUBLIC_APP_NAME="CampaignPulse"
NEXT_PUBLIC_APP_URL="REPLACE_WITH_APP_URL"

# Demo controls
# Keep this as "true" until your real Ace and Dify providers are confirmed.
MOCK_MODE="true"
ALLOW_MOCK_FALLBACK="true"

# Ace Data Cloud
ACE_API_BASE_URL="REPLACE_WITH_ACE_API_BASE_URL"
# Optional fallback key. Use this only if the same key works across all Ace services.
ACE_API_KEY="your-ace-api-key"
# Optional fallback app id. Use only if the same app id works across all Ace services.
ACE_APP_ID="your-ace-app-id"
# If Ace shows a different required app id header name, change this value.
ACE_APP_ID_HEADER="REPLACE_WITH_ACE_APP_ID_HEADER"
# Preferred for this project: paste the key from each service's Keys button.
ACE_IMAGE_API_KEY="your-nano-banana-or-image-key"
ACE_IMAGE_APP_ID="your-image-app-id"
ACE_MUSIC_API_KEY="your-suno-music-key"
ACE_MUSIC_APP_ID="your-music-app-id"
ACE_VIDEO_API_KEY="your-seedance-video-key"
ACE_VIDEO_APP_ID="your-video-app-id"
ACE_SEARCH_API_KEY="your-search-engine-key"
ACE_SEARCH_APP_ID="your-search-app-id"
# Only needed if you later wire Ace QR Art. The app already generates a real local QR.
ACE_QR_API_KEY="your-optional-qr-api-key"
ACE_QR_APP_ID="your-optional-qr-app-id"
# Defaults below match the Ace services used by this app.
ACE_IMAGE_ENDPOINT="REPLACE_WITH_ACE_IMAGE_ENDPOINT"
ACE_IMAGE_MODEL="REPLACE_WITH_ACE_IMAGE_MODEL"
# QR is generated locally as a real scannable QR so the demo works without Ace QR Art.
ACE_QR_ENDPOINT="your-optional-qr-endpoint"
ACE_MUSIC_ENDPOINT="REPLACE_WITH_ACE_MUSIC_ENDPOINT"
ACE_MUSIC_MODEL="REPLACE_WITH_ACE_MUSIC_MODEL"
ACE_VIDEO_ENDPOINT="REPLACE_WITH_ACE_VIDEO_ENDPOINT"
ACE_VIDEO_MODEL="REPLACE_WITH_ACE_VIDEO_MODEL"
ACE_SEARCH_ENDPOINT="REPLACE_WITH_ACE_SEARCH_ENDPOINT"
DIFY_MODEL_LABEL="REPLACE_WITH_DIFY_MODEL_LABEL"
# TODO: Generate this from platform.acedata.cloud if you want x402 order payment.
ACE_PLATFORM_TOKEN="your-platform-token"

# Dify
DIFY_API_BASE_URL="REPLACE_WITH_DIFY_API_BASE_URL"
# TODO: Add your real Dify API key here before enabling live workflow orchestration.
DIFY_API_KEY="your-dify-api-key"
# Optional: paste the app id from the Dify Studio URL for tracking/reference.
DIFY_APP_ID="your-dify-app-id"
# Optional: if set, the app calls /workflows/{workflow_id}/run. If empty, it calls /workflows/run with the app API key.
DIFY_WORKFLOW_ID="your-dify-workflow-id"

# x402
# TODO: Set the Ace order id and Base wallet private key when you wire x402 payment.
ACE_X402_ORDER_ID="your-order-id"
ACE_X402_PRIVATE_KEY="0xyour-base-wallet-private-key"
